{
  "$schema": "https://raw.githubusercontent.com/nickel-org/json-schema-store/main/tauri.schema.json",
  "productName": "DevToolkit",
  "version": "1.0.1",
  "identifier": "com.devtoolkit.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "DevToolkit",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "both",
        "languages": ["SimpChinese", "English"]
      }
    },
    "macOS": {
      "dmg": {
        "windowSize": {
          "width": 660,
          "height": 400
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE3QkVCRkIyNEM1RThEREIKUldUYmpWNU1zcisrRitkUjEzYkRVSUg0bDBzbFJhRjFla1NRSTZ6RHdZRGc4bG8rTktrazM0MDEK",
      "endpoints": [
        "https://github.com/luzhipeng-git/devtoolkit/releases/latest/download/{{target}}-{{arch}}.json"
      ]
    }
  }
}
